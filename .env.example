# Telegram API credentials (get from https://my.telegram.org)
API_ID=123456
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017

# Bot owner user IDs (comma-separated)
OWNERS=123456789,987654321

# Optional: Monitored channels (comma-separated)
MONITORED_CHANNELS=

# Logging configuration
MAX_LOG_AGE_HOURS=24
MAX_LOG_SIZE_BYTES=2097152

# Optional: External OCR service URL (e.g., http://100.118.146.248:8181/api/ocr or http://localhost:8181/api/ocr)
# Leave empty to use internal Tesseract/EasyOCR or Google Drive API
EXTERNAL_OCR_SERVICE_URL=

# Optional: Port for the simple OCR service (default: 8181)
PORT=

